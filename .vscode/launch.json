    "version": "0.2.0",
    "configurations": [
        {
            "name": "exagon_plus",
            "request": "launch",
            "type": "dart",
            "windows": {
                "args": [
                    "--enable-impeller",
                    "--enable-flutter-gpu"
                ]
            }
        },
        {
            "name": "exagon_plus (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "exagon_plus (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}